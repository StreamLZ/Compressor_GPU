# Zig
.zig-cache/
zig-out/
fixtures/

# Assets (large test files)
assets/enwik8.txt
assets/silesia_all.tar
assets/zstd.exe

# Secrets
.nuget-key

# GPU build artifacts — .cubin is regenerated by tools/build_gpu.bat
# (arch-specific, not embedded by the build; only .ptx/.spv are embedded).
*.cubin

# Scratch
b3.txt

# Agent / debugging scratch files in repo root.  Agents have a habit of
# spraying these around during build-capture + temp-data work.  Pattern
# list reflects recurring offenders.
tmp_*
build_*.txt
build_*.log
build_*.out
ptest_*.txt
cu_dbg_*.txt
NUL
*.obj

# Alternate cache + output dirs from build experiments (different
# -Doptimize settings sometimes get redirected here by agent scripts).
.zig-cache-*/
zig-out-*/
